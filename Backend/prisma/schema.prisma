generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  adminId  String @id @default(uuid())
  username String @unique
  password String
  name     String
  role     Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBills Bill[] @relation("AdminCreated")
  updatedBills Bill[] @relation("AdminUpdated")
  roomsCreated Room[] @relation("RoomCreatedBy")
  roomsUpdated Room[] @relation("RoomUpdatedBy")
}

model Room {
  roomId     String @id @default(uuid())
  number     String @unique
  size       String
  rent       Float
  deposit    Float
  bookingFee Float
  status     Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  updatedBy String?

  adminCreated Admin? @relation("RoomCreatedBy", fields: [createdBy], references: [adminId])
  adminUpdated Admin? @relation("RoomUpdatedBy", fields: [updatedBy], references: [adminId])

  bookings  Booking[]
  bills     Bill[]
  checkouts Checkout[]
}

model Customer {
  customerId String  @id @default(uuid())
  userId     String  @unique
  userName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  bills     Bill[]
  payments  Payment[]
  checkouts Checkout[]
}

model Booking {
  bookingId String @id @default(uuid())

  roomId     String
  customerId String

  ctitle   String?
  cname    String?
  csurname String?
  fullName String?
  cphone   String?
  cmumId   String?

  bookingDate DateTime @default(now())

  checkin       DateTime
  checkinAt     DateTime?
  checkinStatus Int       @default(0)

  approveStatus Int       @default(0)
  approvedAt    DateTime?

  slipUrl  String?
  slipPath String?

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  room     Room     @relation(fields: [roomId], references: [roomId])
  customer Customer @relation(fields: [customerId], references: [customerId])

  checkout Checkout?
  bills    Bill[]

  @@index([roomId])
  @@index([roomId, checkinStatus, createdAt])
  @@index([customerId])
  @@index([approveStatus])
}

model Checkout {
  checkoutId String @id @default(uuid())

  bookingId  String @unique
  roomId     String
  customerId String

  checkout DateTime

  ReturnApprovalStatus Int       @default(0)
  RefundApprovalDate   DateTime?

  checkoutStatus Int       @default(0)
  checkoutAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  booking  Booking  @relation(fields: [bookingId], references: [bookingId])
  room     Room     @relation(fields: [roomId], references: [roomId])
  customer Customer @relation(fields: [customerId], references: [customerId])

  @@index([bookingId])
  @@index([checkoutStatus])
  @@index([ReturnApprovalStatus])
}

model Bill {
  billId     String @id @default(uuid())
  billNumber String @unique

  roomId     String?
  customerId String?
  bookingId  String?

  month DateTime

  ctitle   String?
  cname    String?
  csurname String?
  fullName String?
  cphone   String?
  total    Float

  billStatus Int       @default(0)
  billDate   DateTime?
  paidAt     DateTime?

  dueDate DateTime
  slipUrl String?
  slipPath String?

  rent    Float
  service Float

  wBefore   Float
  wAfter    Float
  wUnits    Float
  waterCost Float @default(0)

  eBefore      Float
  eAfter       Float
  eUnits       Float
  electricCost Float @default(0)

  overdueDays Int?   @default(0)
  fine        Float? @default(0)

  lastOverdueNotifyAt DateTime?

  createdAt DateTime  @default(now())
  createdBy String
  updatedAt DateTime?
  updatedBy String?

  room     Room?     @relation(fields: [roomId], references: [roomId])
  booking  Booking?  @relation(fields: [bookingId], references: [bookingId])
  customer Customer? @relation(fields: [customerId], references: [customerId])

  adminCreated Admin?   @relation("AdminCreated", fields: [createdBy], references: [adminId])
  adminUpdated Admin?   @relation("AdminUpdated", fields: [updatedBy], references: [adminId])
  payment      Payment?

  @@index([createdAt])
  @@index([billStatus])
  @@index([roomId, month])
}

model Payment {
  paymentId  String @id @default(uuid())
  billId     String @unique
  customerId String

  paidAt  DateTime?
  slipUrl String?
  slipPath String?

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  bill     Bill     @relation(fields: [billId], references: [billId])
  customer Customer @relation(fields: [customerId], references: [customerId])

  @@index([customerId])
}

model DormProfile {
  dormId String @id @default(uuid())

  key String @unique @default("MAIN")

  dormName String
  address  String
  phone    String
  email    String

  taxId   String
  taxType Int    @default(0)

  receiverTitle    String?
  receiverName     String?
  receiverSurname  String?
  receiverFullName String?

  service           Float
  waterRate         Float
  electricRate      Float
  overdueFinePerDay Float

  signatureUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
