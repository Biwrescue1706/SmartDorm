generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  adminId   String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

createdBills Bill[] @relation("AdminCreated")
  updatedBills Bill[] @relation("AdminUpdated")
}

model Customer {
  customerId String   @id @default(uuid())
  userId     String   @unique
  userName   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bookings   Booking[]
  bills      Bill[]
  payments   Payment[]
  checkouts  Checkout[]
}

model Room {
  roomId     String   @id @default(uuid())
  number     String   @unique
  size       String
  rent       Float
  deposit    Float
  bookingFee Float
  status     Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bookings   Booking[]
  bills      Bill[]
}

model Booking {
  bookingId      String   @id @default(uuid())
  roomId         String
  customerId     String

  fullName       String
  cphone         String

  approveStatus  Int      @default(0)
  checkinStatus  Int      @default(0)

  bookingDate    DateTime @default(now())
  checkinAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  room           Room     @relation(fields: [roomId], references: [roomId])
  customer       Customer @relation(fields: [customerId], references: [customerId])

  bills          Bill[]
  checkouts      Checkout[]

  @@index([roomId, checkinStatus, createdAt]) 
}

model Bill {
  billId      String   @id @default(uuid())
  billNumber  String   @unique

  roomId      String
  bookingId   String
  customerId  String

  month       DateTime
  dueDate     DateTime

  rent        Float
  service     Float

  wBefore     Float
  wAfter      Float
  wUnits      Float
  waterCost   Float

  eBefore     Float
  eAfter      Float
  eUnits      Float
  electricCost Float

  total       Float

  billStatus  Int      @default(0)

  slipUrl     String?
  paidAt      DateTime?

  overdueDays Int?
  fine        Float?

createdBy   String?   // 👈 เพิ่ม
  updatedBy   String?   // 👈 เพิ่ม

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room        Room     @relation(fields: [roomId], references: [roomId])
  booking     Booking  @relation(fields: [bookingId], references: [bookingId])
  customer    Customer @relation(fields: [customerId], references: [customerId])

adminCreated Admin? @relation("AdminCreated", fields: [createdBy], references: [adminId])
  adminUpdated Admin? @relation("AdminUpdated", fields: [updatedBy], references: [adminId])

  payment     Payment?

  @@index([createdAt])        // 🔥 list
  @@index([roomId, month])    // 🔥 สำคัญสุด
}

model Payment {
  paymentId  String   @id @default(uuid())
  billId     String   @unique
  customerId String

  slipUrl    String
  paidAt     DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bill       Bill     @relation(fields: [billId], references: [billId])
  customer   Customer @relation(fields: [customerId], references: [customerId])

  @@index([customerId])
}

model Checkout {
  checkoutId String   @id @default(uuid())
  bookingId  String
  customerId String

  checkoutStatus        Int @default(0)
  ReturnApprovalStatus  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking  @relation(fields: [bookingId], references: [bookingId])
  customer  Customer @relation(fields: [customerId], references: [customerId])

  @@index([bookingId])
}

model DormProfile {
  key   String @id @default("MAIN")

  dormName  String?
  address   String?
  phone     String?
  email     String?
  taxId     String?
  taxType   Int?

  receiverTitle   String?
  receiverName    String?
  receiverSurname String?
  receiverFullName String?

  signatureUrl String?

  service            Float?
  waterRate          Float?
  electricRate       Float?
  overdueFinePerDay  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
